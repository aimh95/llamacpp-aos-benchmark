# build artifacts
build-android/
cmake-build*/
*.o
*.a
*.so

# models (binary weights — kept locally, not tracked in git)
**/*.gguf
**/*.safetensors
**/*.pth
**/*.bin
!models/*/README.md
!models/README.md

# python cache
__pycache__/
*.pyc
*.pyo

# logs
logs/*.log
logs/*.json
logs/*.txt
!logs/.gitkeep

# device probe raw output (per-device dumps, regenerable)
artifacts/device_probe/*/
!artifacts/device_probe/.gitkeep

# htp smoke raw output (per-run dumps, regenerable)
artifacts/htp_smoke/*/
!artifacts/htp_smoke/.gitkeep

# snapdragon build/check/install raw output (per-run dumps, regenerable)
artifacts/build_snapdragon/*/
!artifacts/build_snapdragon/.gitkeep

# graph dump outputs (regenerable — produced by DUMP_GGML_GRAPH=1)
experiments/graph_dump/*.dot
experiments/graph_dump/*.txt
!experiments/graph_dump/.gitkeep

# backend flow experiment outputs (regenerable)
experiments/backend_flow/*.txt
experiments/backend_flow/*.csv
experiments/backend_flow/*.log
experiments/backend_flow/summary.md
!experiments/backend_flow/.gitkeep
!experiments/backend_flow/parse_backflow.py

# htp smoke trace logs (large, regenerable)
artifacts/htp_smoke/*.log

# tied embedding experiment outputs (regenerable)
experiments/tied_embedding_exaone4_1p2b/tied_on/*.log
experiments/tied_embedding_exaone4_1p2b/tied_on/*.txt
experiments/tied_embedding_exaone4_1p2b/tied_on/*.json
experiments/tied_embedding_exaone4_1p2b/tied_on/*.dot
experiments/tied_embedding_exaone4_1p2b/tied_on/*.md
!experiments/tied_embedding_exaone4_1p2b/tied_on/.gitkeep
experiments/tied_embedding_exaone4_1p2b/tied_off/*.log
experiments/tied_embedding_exaone4_1p2b/tied_off/*.txt
experiments/tied_embedding_exaone4_1p2b/tied_off/*.json
experiments/tied_embedding_exaone4_1p2b/tied_off/*.dot
experiments/tied_embedding_exaone4_1p2b/tied_off/*.md
!experiments/tied_embedding_exaone4_1p2b/tied_off/.gitkeep
experiments/tied_embedding_exaone4_1p2b/summary.md

# os / editor
.DS_Store
