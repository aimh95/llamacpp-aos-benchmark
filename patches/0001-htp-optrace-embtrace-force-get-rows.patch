--- a/ggml/src/ggml-hexagon/htp/get-rows-ops.c
+++ b/ggml/src/ggml-hexagon/htp/get-rows-ops.c
@@ -148,9 +148,127 @@ static void get_rows_thread_f32_f32_hvx(unsigned int nth, unsigned int ith, void
