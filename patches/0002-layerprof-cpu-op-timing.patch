diff --git a/ggml/src/ggml-cpu/ggml-cpu.c b/ggml/src/ggml-cpu/ggml-cpu.c
index eb8341c9a..5f9ec702f 100644
--- a/ggml/src/ggml-cpu/ggml-cpu.c
+++ b/ggml/src/ggml-cpu/ggml-cpu.c
@@ -3015,6 +3015,18 @@ static int ggml_cpu_try_fuse_ops(
     return 0;
 }
 
+// [LAYERPROF] per-op CPU timing. env GGML_LAYER_PROFILE=timing|1 일 때만 동작(assignment/0 은 off).
+// thread 0 만 barrier 전후로 재어 왜곡 최소화. 그래프 실행 카운터 g 로 prefill/decode 구분(파서에서 분류).
+static int ggml_lp_enabled(void) {
+    static int v = -1;
+    if (v < 0) {
+        const char * e = getenv("GGML_LAYER_PROFILE");
+        v = (e && e[0] && strcmp(e, "0") != 0 && strcmp(e, "assignment") != 0) ? 1 : 0;
+    }
+    return v;
+}
+static int ggml_lp_gcall = 0;
+
 static thread_ret_t ggml_graph_compute_thread(void * data) {
     struct ggml_compute_state * state = (struct ggml_compute_state *) data;
     struct ggml_threadpool    * tp    = state->threadpool;
@@ -3043,6 +3055,10 @@ static thread_ret_t ggml_graph_compute_thread(void * data) {
     GGML_PRINT_DEBUG("thread #%d compute-start cplan %p last-graph %d\n", state->ith, (const void *)cplan, state->last_graph);
 #endif
 
+    const int lp_on = ggml_lp_enabled();
+    if (lp_on && state->ith == 0) { ggml_lp_gcall++; }
+    const int lp_g = ggml_lp_gcall;
+
     for (int node_n = 0; node_n < cgraph->n_nodes && atomic_load_explicit(&tp->abort, memory_order_relaxed) != node_n; node_n++) {
         struct ggml_tensor * node = cgraph->nodes[node_n];
 
@@ -3055,6 +3071,8 @@ static thread_ret_t ggml_graph_compute_thread(void * data) {
             continue;
         }
 
+        const int64_t lp_t0 = (lp_on && state->ith == 0) ? ggml_time_us() : 0;
+
         // TODO: move fused-op detection into ggml_graph_plan so fusion decisions are made once at planning time
         // Try fused ops, fall back to normal compute
         const int n_fused = ggml_cpu_try_fuse_ops(cgraph, node_n, &params, cplan);
@@ -3073,6 +3091,13 @@ static thread_ret_t ggml_graph_compute_thread(void * data) {
         if (node_n + 1 < cgraph->n_nodes) {
             ggml_barrier(state->threadpool);
         }
+
+        // [LAYERPROF] thread 0: barrier 이후 = 이 노드(융합 포함) 완료. dst 이름으로 op_compare 에 join.
+        if (lp_on && state->ith == 0) {
+            fprintf(stderr, "[LAYERPROF] g=%d op=%s dst=\"%s\" us=%lld nf=%d\n",
+                    lp_g, ggml_op_name(node->op), node->name,
+                    (long long)(ggml_time_us() - lp_t0), n_fused);
+        }
     }
 
 #ifdef GGML_USE_OPENMP
